# Copy to .env (gitignored). Auto-loaded at startup; no dotenv dep needed.
# Path to the PerfScript repo's "backend" folder (the reused engine).
# Leave blank to let engine.js try common sibling layouts.
PERFSCRIPT_ENGINE=
# JMeter install (only needed for --run / --fast-loop with TLS to staging).
JMETER_HOME=
# OpenAI is the preferred provider for safe bounded agent escalation.
OPENAI_API_KEY=
# Default senior performance engineer model.
OPENAI_MODEL=gpt-5.5

# Gemini fallback for safe bounded agent escalation (optional).
GOOGLE_API_KEY=
# Default: gemini-3.5-flash. Use gemini-3.1-pro-preview for Pro.
GOOGLE_MODEL=gemini-3.5-flash
