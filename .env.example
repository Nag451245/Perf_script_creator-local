# Copy to .env (gitignored). Auto-loaded at startup; no dotenv dep needed.
# Path to the PerfScript repo's "backend" folder (the reused engine).
# Leave blank to let engine.js try common sibling layouts.
PERFSCRIPT_ENGINE=
# JMeter install (only needed for --run / --fast-loop with TLS to staging).
JMETER_HOME=
# Gemini key for Phase 4 LLM escalation (optional).
GOOGLE_API_KEY=
