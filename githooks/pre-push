#!/bin/sh
# Block pushes that break the test suite. Enabled via `npm install` (which runs
# the prepare script: git config core.hooksPath githooks), or manually:
#   git config core.hooksPath githooks
# Override in a pinch with: git push --no-verify
NODE="node"
command -v node >/dev/null 2>&1 || NODE="$LOCALAPPDATA/nodejs22/node.exe"
echo "pre-push: running test suite…"
"$NODE" --test
status=$?
if [ $status -ne 0 ]; then
  echo "pre-push: tests FAILED — push aborted. (git push --no-verify to override)"
  exit 1
fi
echo "pre-push: tests passed."
exit 0
